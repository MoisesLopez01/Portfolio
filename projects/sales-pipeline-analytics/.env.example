# Copy to .env and fill in for LIVE API extraction. The demo runs from a local
# JSON file and needs none of these.

# Base URL of the CRM deals endpoint (cursor-paginated REST API).
CRM_API_BASE_URL=https://api.example-crm.com/v3/objects/deals

# API token (sent as a Bearer header — never hard-coded in source).
CRM_API_KEY=

# Warehouse target. SQLite path for the demo; swap for a BigQuery/Snowflake DSN
# in production.
WAREHOUSE_DB_PATH=warehouse.db
